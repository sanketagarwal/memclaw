# ─────────────────────────────────────────────────────────────────────────────
# memclaw configuration — copy this file to `.env` and fill in what you need.
# `npm run setup` does this for you interactively.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model provider (required) ────────────────────────────────────────────────
# memclaw defaults to OpenAI. Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# The agent model, in Mastra's `provider/model` routing format.
# Examples: openai/gpt-5-mini (default, cheap), openai/gpt-5.5,
#           anthropic/claude-haiku-4-5 (needs ANTHROPIC_API_KEY).
MEMCLAW_MODEL=openai/gpt-5-mini

# Model used by Observational Memory's background Observer/Reflector agents.
# Keep this on a fast, cheap model.
MEMCLAW_MEMORY_MODEL=openai/gpt-5-mini

# ── Event bus / pub-sub backend ──────────────────────────────────────────────
# memory  -> in-process EventEmitter + replay cache (default, zero infra)
# unix    -> Unix domain socket, shares the bus across processes on one host
# redis   -> distributed across hosts (requires `npm i @mastra/redis-streams`)
MEMCLAW_PUBSUB=memory
MEMCLAW_PUBSUB_SOCKET=/tmp/mastra/memclaw.sock
# REDIS_URL=redis://localhost:6379

# ── Browser use (optional) ───────────────────────────────────────────────────
# Set to "true" to give the agent a real Playwright browser (live screencast in
# Studio). Run `npx playwright install chromium` once before enabling.
MEMCLAW_BROWSER=false
MEMCLAW_BROWSER_HEADLESS=true

# ── Tools (optional) ─────────────────────────────────────────────────────────
# Shell access is powerful and dangerous. Off by default. Only enable on a
# machine you control and trust.
MEMCLAW_ENABLE_SHELL=false

# ── Capabilities (optional) ──────────────────────────────────────────────────
# Built-in capabilities load automatically. To add capabilities published as npm
# packages, install them and list them here (comma-separated). See
# docs/capabilities.md. Example:
# MEMCLAW_CAPABILITIES=@memclaw/github,memclaw-cap-notion

# ── Connectors / channels (optional) ─────────────────────────────────────────
# Add credentials for any platform you want to connect, then run `mastra dev`.
# Telegram works over long-polling with NO public URL needed — easiest to start.
# TELEGRAM_BOT_TOKEN=
# Slack & Discord need a public webhook URL (use `ngrok http 4111` locally).
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=
