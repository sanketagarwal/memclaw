# ─────────────────────────────────────────────────────────────────────────────
# memclaw configuration — copy this file to `.env` and fill in what you need.
# `npm run setup` does this for you interactively.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model provider (required) ────────────────────────────────────────────────
# memclaw defaults to OpenAI. Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# The agent model, in Mastra's `provider/model` routing format.
# Examples: openai/gpt-5-mini (default, cheap), openai/gpt-5.5,
#           anthropic/claude-haiku-4-5 (needs ANTHROPIC_API_KEY).
MEMCLAW_MODEL=openai/gpt-5-mini

# Model used by Observational Memory's background Observer/Reflector agents.
# Keep this on a fast, cheap model.
MEMCLAW_MEMORY_MODEL=openai/gpt-5-mini

# ── Event bus / pub-sub backend ──────────────────────────────────────────────
# memory  -> in-process EventEmitter + replay cache (default, zero infra)
# unix    -> Unix domain socket, shares the bus across processes on one host
# redis   -> distributed across hosts (requires `npm i @mastra/redis-streams`)
MEMCLAW_PUBSUB=memory
MEMCLAW_PUBSUB_SOCKET=/tmp/mastra/memclaw.sock
# REDIS_URL=redis://localhost:6379

# ── Browser use (optional) ───────────────────────────────────────────────────
# Set to "true" to give the agent a real Playwright browser (live screencast in
# Studio). Run `npx playwright install chromium` once before enabling.
MEMCLAW_BROWSER=false
MEMCLAW_BROWSER_HEADLESS=true

# ── Workspace: local filesystem + shell (optional) ───────────────────────────
# Gives the agent file tools (read/write/edit/list/grep) and a sandbox to run
# commands, rooted at MEMCLAW_WORKSPACE_DIR. Writes/deletes/commands are
# approval-gated, and writes require reading the file first. Powerful — enable
# only on a machine you control.
MEMCLAW_WORKSPACE=false
MEMCLAW_WORKSPACE_DIR=./workspace

# ── Proactive scheduler: 24/7 autonomous runs (optional) ─────────────────────
# When enabled, Mastra's built-in scheduler fires a workflow on this cron that
# runs the agent and publishes the result to the bus (visible in Studio's
# Schedules view). Needs a long-lived process (run memclaw as a daemon).
MEMCLAW_SCHEDULE=false
MEMCLAW_SCHEDULE_CRON=0 8 * * *
# MEMCLAW_SCHEDULE_TIMEZONE=America/New_York
# MEMCLAW_SCHEDULE_PROMPT=Proactive check-in: give me a brief, useful daily digest.
# Deliver the result to a chat. Format: telegram:<chatId> or slack:<channelId>.
# Needs the matching bot token below. Omit to keep results bus-only.
# To find your Telegram chat id: message your bot, then open
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates  and read result[].message.chat.id
# MEMCLAW_SCHEDULE_DELIVER_TO=telegram:123456789

# ── Inbound webhooks → agent signals (optional) ──────────────────────────────
# Accept webhooks from external systems (GitHub, Stripe, a CRM, sensors…). Each
# event becomes a notification signal injected into a subscribed conversation.
# Mounts POST /webhooks/:source and mirrors every event onto the bus. Needs a
# public URL for real providers (tunnel locally). See docs/webhooks.md.
MEMCLAW_WEBHOOKS=false

# ── Multi-agent team (optional) ──────────────────────────────────────────────
# Register the example `research-team` orchestrator (a supervisor managing a
# researcher + writer, each with its own memory). Build your own with the
# defineOrchestrator/defineSpecialist helpers — see docs/multi-agent.md.
MEMCLAW_TEAM=false

# ── Capabilities (optional) ──────────────────────────────────────────────────
# Built-in capabilities load automatically. To add capabilities published as npm
# packages, install them and list them here (comma-separated). See
# docs/capabilities.md. Example:
# MEMCLAW_CAPABILITIES=@memclaw/github,memclaw-cap-notion

# To connect external MCP tool servers (GitHub, filesystem, Notion, …), copy
# memclaw.mcp.json.example to memclaw.mcp.json. Override its path here if needed:
# MEMCLAW_MCP_CONFIG=memclaw.mcp.json

# ── Connectors / channels (optional) ─────────────────────────────────────────
# Add credentials for any platform you want to connect, then run `mastra dev`.
# Telegram works over long-polling with NO public URL needed — easiest to start.
# TELEGRAM_BOT_TOKEN=
# Slack & Discord need a public webhook URL (use `ngrok http 4111` locally).
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=
